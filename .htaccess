# PharmaCMS - Root .htaccess
Options -Indexes
DirectoryIndex index.php

# PHP settings for file uploads
<IfModule mod_php.c>
    php_value upload_max_filesize 512M
    php_value post_max_size 520M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Block access to sensitive files
<FilesMatch "\.(sql|env|log|bak|old|orig|save|swp|swo)$">
    Require all denied
</FilesMatch>

# Block direct access to config and db files
<FilesMatch "^(config|db|composer)\.(php|json|lock|phar)$">
    <If "%{REQUEST_URI} =~ m#^/(config|db|composer)\.#">
        Require all denied
    </If>
</FilesMatch>
